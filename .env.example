# From PC (Prisma, local Next): host port 15432 maps to Postgres in Docker (see docker-compose).
DATABASE_URL="postgresql://postgres:postgres@localhost:15432/smartwarehouse?schema=public"

# JWT cookie signing — must be at least 32 characters (use a long random string in production)
AUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# First admin user (used by `npm run db:seed`)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123"
