# Prisma and npm run dev on your PC: use localhost and the host port mapped in docker-compose (15432).
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/smartwarehouse?schema=public

# Required for login (JWT). Must be at least 32 characters. Change in production.
AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Used by: npm run db:seed (first admin account)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
